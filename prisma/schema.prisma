generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Profile {
  id          String   @id @db.Uuid
  role        String   @default("user")
  displayName String?  @map("display_name")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("profiles")
}

model Course {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  description String?
  sourceKey   String?   @unique @map("source_key")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  chapters    Chapter[]

  @@map("courses")
}

model Chapter {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseId    String   @map("course_id") @db.Uuid
  title       String
  description String?
  chapterKey  String?  @unique @map("chapter_key")
  section     String?
  orderIndex  Int      @map("order_index")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons     Lesson[]
  quizzes     Quiz[]

  @@index([courseId])
  @@map("chapters")
}

model Lesson {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chapterId       String            @map("chapter_id") @db.Uuid
  title           String
  contentType     String?           @map("content_type")
  contentUrl      String?           @map("content_url")
  simulatorConfig Json?             @map("simulator_config")
  legacyLessonId  String?           @map("legacy_lesson_id")
  fullId          String?           @map("full_id")
  lessonType      String?           @map("lesson_type")
  simContent      String?           @map("sim_content")
  contentText     String?           @map("content_text")
  orderIndex      Int               @map("order_index")
  isActive        Boolean           @default(true) @map("is_active")
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamp(6)
  chapter         Chapter           @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  sources         LessonSource[]
  userProgress    UserProgress[]
  learningSessions LearningSession[]

  @@index([chapterId])
  @@unique([chapterId, legacyLessonId], map: "lessons_chapter_id_legacy_lesson_id_key")
  @@map("lessons")
}

model LessonSource {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lessonId    String   @map("lesson_id") @db.Uuid
  rawContent  String?  @map("raw_content")
  aiProcessed Json?    @map("ai_processed")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@map("lesson_sources")
}

model Quiz {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chapterId    String       @map("chapter_id") @db.Uuid
  title        String
  timeLimit    Int?         @map("time_limit")
  passingScore Int          @default(60) @map("passing_score")
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamp(6)
  chapter      Chapter      @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  questions    Question[]
  userAnswers  UserAnswer[]
  learningSessions LearningSession[]

  @@index([chapterId])
  @@map("quizzes")
}

model Question {
  id                  String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quizId              String       @map("quiz_id") @db.Uuid
  questionText        String?      @map("question_text")
  questionImageUrl    String?      @map("question_image_url")
  questionType        String       @default("single_choice") @map("question_type")
  options             Json?
  correctAnswer       String       @map("correct_answer")
  explanation         String?
  explanationImageUrl String?      @map("explanation_image_url")
  score               Int          @default(1)
  orderIndex          Int          @map("order_index")
  createdAt           DateTime     @default(now()) @map("created_at") @db.Timestamp(6)
  quiz                Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  userAnswers         UserAnswer[]

  @@index([quizId])
  @@map("questions")
}

model UserProgress {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String   @map("user_id") @db.Uuid
  lessonId           String   @map("lesson_id") @db.Uuid
  status             String   @default("not_started")
  progressPercentage Int      @default(0) @map("progress_percentage")
  startedAt          DateTime? @map("started_at") @db.Timestamp(6)
  completedAt        DateTime? @map("completed_at") @db.Timestamp(6)
  lastAccessedAt     DateTime? @map("last_accessed_at") @db.Timestamp(6)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt          DateTime @updatedAt @default(now()) @map("updated_at") @db.Timestamp(6)
  lesson             Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId], map: "user_progress_user_id_lesson_id_key")
  @@index([lessonId])
  @@index([userId])
  @@map("user_progress")
}

model LearningSession {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  lessonId  String?   @map("lesson_id") @db.Uuid
  quizId    String?   @map("quiz_id") @db.Uuid
  startTime DateTime  @map("start_time") @db.Timestamp(6)
  endTime   DateTime? @map("end_time") @db.Timestamp(6)
  duration  Int?
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  lesson    Lesson?   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  quiz      Quiz?     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@index([quizId])
  @@index([userId])
  @@map("learning_sessions")
}

model UserAnswer {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  quizId     String    @map("quiz_id") @db.Uuid
  questionId String    @map("question_id") @db.Uuid
  answer     String?
  isCorrect  Boolean?  @map("is_correct")
  score      Int?
  answeredAt DateTime  @default(now()) @map("answered_at") @db.Timestamp(6)
  quiz       Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
  question   Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId], map: "user_answers_user_id_question_id_key")
  @@index([quizId])
  @@index([questionId])
  @@index([userId])
  @@map("user_answers")
}
